{
  "compilerOptions": {
    "types": ["obsidian-typings", "node"],
    "paths": {
      "obsidian-typings/implementations": [
        "./node_modules/obsidian-typings/dist/cjs/implementations.d.cts",
        "./node_modules/obsidian-typings/dist/esm/implementations.mjs"
      ]
    },
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "inlineSourceMap": true,
    "inlineSources": true,
    "esModuleInterop": true,
    "allowJs": true,
    "noImplicitAny": true,
    "importHelpers": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2024"]
  },
  "include": ["./src/**/*.ts", "./scripts/**/*.ts"],
  "exclude": ["node_modules", "eslint.config.ts", "templates-for-obsidian"]
}
